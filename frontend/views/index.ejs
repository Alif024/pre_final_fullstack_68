<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Data</title>
</head>
<body>
  <h1>Student Data</h1>
  <table>
    <tr>
      <th>ID</th>
      <th>Student Code</th>
      <th>Full Name</th>
      <th>Major</th>
      <th>Created At</th>
      <th>Updated At</th>
    </tr>
    <% students.forEach((student) => { %>
      <tr>
        <td><%= student.id %></td>
        <td><%= student.student_code %></td>
        <td><%= student.full_name %></td>
        <td><%= student.major %></td>
        <td><%= student.createdAt %></td>
        <td><%= student.updatedAt %></td>
      </tr>
    <% }) %>
  </table>

  <h1>Subject Data</h1>
  <table>
    <tr>
      <th>ID</th>
      <th>Subject Code</th>
      <th>Subject Name</th>
      <th>Credits</th>
      <th>Created At</th>
      <th>Updated At</th>
    </tr>
    <% subjects.forEach((subject) => { %>
      <tr>
        <td><%= subject.id %></td>
        <td><%= subject.subject_code %></td>
        <td><%= subject.subject_name %></td>
        <td><%= subject.credits %></td>
        <td><%= subject.createdAt %></td>
        <td><%= subject.updatedAt %></td>
      </tr>
    <% }) %>
  </table>

  <h1>Enrollment Data</h1>
  <table>
    <tr>
      <th>ID</th>
      <th>Student ID</th>
      <th>Subject ID</th>
      <th>Semester</th>
      <th>Grade</th>
      <th>Created At</th>
      <th>Updated At</th>
    </tr>
    <% enrollments.forEach((enrollment) => { %>
      <tr>
        <td><%= enrollment.id %></td>
        <td><%= enrollment.student_id %></td>
        <td><%= enrollment.subject_id %></td>
        <td><%= enrollment.semester %></td>
        <td><%= enrollment.grade %></td>
        <td><%= enrollment.createdAt %></td>
        <td><%= enrollment.updatedAt %></td>
      </tr>
    <% }) %>
  </table>
</body>
</html>
